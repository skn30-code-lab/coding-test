def solution(signals):
    # 유클리드 호제법을 사용하여 두 수(a, b)의 최대공약수(GCD)를 구하는 함수입니다.
    def get_gcd(a, b):
        while b > 0:
            # a를 b로 나눈 나머지를 새로운 b로, 기존 b를 새로운 a로 갱신하며 b가 0이 될 때까지 반복합니다.
            a, b = b, a % b
        # b가 0이 되었을 때의 a 값이 최대공약수입니다.
        return a

    # 최대공약수를 활용하여 두 수(a, b)의 최소공배수(LCM)를 구하는 함수입니다.
    def get_lcm(a, b):
        # 두 수의 곱을 최대공약수로 나누면 최소공배수가 도출됩니다.
        return (a * b) // get_gcd(a, b)
    
    # 탐색의 상한선(모든 신호등 주기의 최소공배수)을 저장할 변수입니다. 곱셈 연산을 위해 초기값은 1로 설정합니다.
    max_limit = 1
    
    # 주어진 모든 신호등의 주기를 순회하며 전체 최소공배수를 계산합니다.
    for g, y, r in signals:
        # g(초록) + y(노랑) + r(빨강)은 해당 신호등의 1회 사이클 주기입니다.
        # 기존 max_limit과 현재 신호등 주기의 최소공배수를 구해 max_limit을 누적 갱신합니다.
        max_limit = get_lcm(max_limit, g + y + r)
        
    # 0초부터 전체 최소공배수(max_limit) - 1초까지 1초씩 증가시키며 완전 탐색을 수행합니다.
    # (시간 단위를 0부터 시작하는 것으로 치환하여 모듈러(%) 연산을 용이하게 합니다.)
    for t in range(max_limit):
        # 현재 시간 t에서 모든 신호등이 노란불인지 판별하기 위한 상태 변수입니다. 기본값은 True입니다.
        all_yellow = True
        
        # 각 시간 t마다 모든 신호등의 상태를 개별적으로 확인합니다.
        for g, y, r in signals:
            # t를 해당 신호등의 전체 주기(g + y + r)로 나눈 나머지 연산을 통해, 현재 주기의 진행 시점(초)을 구합니다.
            rem = t % (g + y + r)
            
            # 초록불이 끝난 시점(g)부터 노란불이 끝나는 시점(g + y) 미만이 노란불 점등 구간입니다.
            # 현재 경과 시간(rem)이 이 구간에 속하지 않는다면 현재 신호등은 노란불이 아닙니다.
            if not (g <= rem < g + y):
                # 단 하나라도 노란불이 아니면 전체가 노란불이라는 조건이 깨지므로 상태를 False로 변경합니다.
                all_yellow = False
                # 나머지 신호등은 더 이상 검사할 필요가 없으므로 내부 반복문을 즉시 탈출합니다.
                break
                
        # 하나의 시간 t에 대해 모든 신호등 검사를 마쳤을 때 all_yellow가 여전히 True라면, 전체 신호등이 노란불 상태입니다.
        if all_yellow:
            # 내부 연산 기준은 0초부터 시작했으나 실제 문제는 1초부터 시작하므로 t + 1을 반환합니다.
            return t + 1
            
    # 최소공배수(모든 주기가 완전히 겹쳐 처음으로 동기화되는 시점)까지 탐색했음에도 노란불이 겹치지 않았다면,
    # 이후로도 똑같은 패턴이 반복될 뿐 영원히 겹치는 구간이 발생하지 않으므로 -1을 반환합니다.
    return -1
